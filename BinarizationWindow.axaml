<Window
    x:Class="SCOI_Lab_1.BinarizationWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Бинаризация изображения"
    Width="1160"
    Height="820"
    MinWidth="980"
    MinHeight="700"
    WindowStartupLocation="CenterOwner">
  <Grid
      Margin="16"
      ColumnDefinitions="*,360"
      RowDefinitions="Auto,*,Auto"
      ColumnSpacing="16"
      RowSpacing="12">
    <TextBlock
        Grid.Row="0"
        Grid.Column="0"
        Text="Оригинал и предпросмотр"
        FontSize="22"
        FontWeight="Bold" />

    <Grid
        Grid.Row="1"
        Grid.Column="0"
        ColumnDefinitions="*,*"
        ColumnSpacing="16">
      <Border
          Background="#F3F4F6"
          BorderBrush="#CBD5E1"
          BorderThickness="1"
          CornerRadius="12"
          Padding="12">
        <StackPanel Spacing="8">
          <TextBlock Text="Исходное изображение" FontSize="16" FontWeight="SemiBold" />
          <Image
              x:Name="OriginalImage"
              Height="620"
              Stretch="Uniform" />
        </StackPanel>
      </Border>

      <Border
          Grid.Column="1"
          Background="#F8FAFC"
          BorderBrush="#CBD5E1"
          BorderThickness="1"
          CornerRadius="12"
          Padding="12">
        <StackPanel Spacing="8">
          <TextBlock Text="Результат" FontSize="16" FontWeight="SemiBold" />
          <Image
              x:Name="PreviewImage"
              Height="620"
              Stretch="Uniform" />
        </StackPanel>
      </Border>
    </Grid>

    <Border
        Grid.Row="0"
        Grid.RowSpan="3"
        Grid.Column="1"
        Background="#F8FAFC"
        BorderBrush="#CBD5E1"
        BorderThickness="1"
        CornerRadius="12"
        Padding="16">
      <StackPanel Spacing="12">
        <TextBlock
            Text="Параметры"
            FontSize="20"
            FontWeight="Bold" />

        <TextBlock Text="Метод бинаризации" />
        <ComboBox
            x:Name="MethodComboBox"
            SelectionChanged="MethodComboBox_SelectionChanged" />

        <TextBlock
            x:Name="WindowSizeLabel"
            Text="Размер окна" />
        <TextBox
            x:Name="WindowSizeTextBox"
            Watermark="Например, 25" />

        <TextBlock
            x:Name="SensitivityLabel"
            Text="Чувствительность / k" />
        <TextBox
            x:Name="SensitivityTextBox"
            Watermark="Например, -0.2 или 0.15" />

        <Border
            Background="White"
            BorderBrush="#E2E8F0"
            BorderThickness="1"
            CornerRadius="10"
            Padding="12">
          <TextBlock
              x:Name="MethodDescriptionText"
              TextWrapping="Wrap" />
        </Border>

        <TextBlock
            x:Name="StatusText"
            Foreground="#475569"
            Text="Готово к расчёту" />

        <Button
            x:Name="PreviewButton"
            Height="42"
            Content="Построить предпросмотр"
            Click="PreviewButton_Click" />
        <Button
            x:Name="ApplyButton"
            Height="42"
            Content="Применить к слою"
            Click="ApplyButton_Click" />
        <Button
            Height="42"
            Content="Отмена"
            Click="CancelButton_Click" />
      </StackPanel>
    </Border>

    <TextBlock
        Grid.Row="2"
        Grid.Column="0"
        Foreground="#64748B"
        Text="Для 45+ по методичке у вас должны быть все методы, параметры без хардкода и нормальная оптимизация вычислений."
        TextWrapping="Wrap" />
  </Grid>
</Window>
